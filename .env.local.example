# Supabase - configure na Vercel
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-side (API routes for n8n cron)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: secure API for n8n (daily report recipients)
CRON_SECRET=
# or N8N_CRON_SECRET=

# Optional: push recipients to n8n webhook (POST /api/n8n/sync-recipients)
N8N_WEBHOOK_URL=
